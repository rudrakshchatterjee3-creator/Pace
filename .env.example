# ─── SERVER-SIDE (set in Cloud Run; NEVER commit real values) ───────────────
# The Gemini key lives ONLY on the server. The browser never sees it.
GEMINI_API_KEY=your_gemini_api_key_here

# Model used by the /api/agent proxy. Flash = fast+cheap (default). Escalate to
# gemini-3.1-pro only for heavy reasoning steps.
GEMINI_MODEL=gemini-3.5-flash

# Cloud Run injects PORT automatically. 8080 is the local/default fallback.
PORT=8080

# ─── CLIENT-SIDE (Vite exposes anything prefixed VITE_ to the browser) ───────
# Only put NON-SECRET values here.
VITE_APP_NAME=PromptWars Demo

# If you use Google Maps in the browser, restrict this key by HTTP referrer in
# the Google Cloud console before shipping.
# VITE_GOOGLE_MAPS_API_KEY=your_browser_restricted_maps_key
